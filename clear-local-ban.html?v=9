<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Oliom Horizons — Clear Local Ban Cache</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="stylesheet" href="style.css">
</head>
<body>
  <main>
    <section class="block" style="max-width:720px;margin:40px auto;">
      <h1 style="margin-top:0;">Clear Local Ban Cache</h1>
      <p>This clears the browser-side device id and old local moderation cache.</p>
      <button id="clearBtn" class="btn primary">Clear and go to Games</button>
      <pre id="log" style="white-space:pre-wrap;border:1px solid #d6efcf;border-radius:12px;padding:10px;background:#fff;color:#667868;"></pre>
    </section>
  </main>
  <script>
    const log = document.getElementById("log");
    document.getElementById("clearBtn").onclick = () => {
      localStorage.removeItem("oh_device_id_v1");
      sessionStorage.clear();
      log.textContent = "Cleared oh_device_id_v1 and sessionStorage. Redirecting...";
      setTimeout(() => location.href = "server.html?v=9", 700);
    };
  </script>
</body>
</html>
